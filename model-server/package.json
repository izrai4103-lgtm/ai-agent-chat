{
  "name": "passeo-hermes-model-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "local:gemma": "bash ./watch-local-gemma.sh once",
    "watch:gemma": "bash ./watch-local-gemma.sh watch",
    "status:gemma": "bash ./watch-local-gemma.sh status",
    "hf:gemma": "bash ./watch-local-hf-gemma.sh once",
    "watch:hf-gemma": "bash ./watch-local-hf-gemma.sh watch",
    "status:hf-gemma": "bash ./watch-local-hf-gemma.sh status",
    "tunnel:cloudflare": "cloudflared tunnel --url http://127.0.0.1:${PORT:-8080} --no-autoupdate",
    "watch:tunnel": "bash ./watch-cloudflare-tunnel.sh watch",
    "status:tunnel": "bash ./watch-cloudflare-tunnel.sh status"
  },
  "engines": {
    "node": ">=20"
  }
}
